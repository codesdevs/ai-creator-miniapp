<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.AiModelMapper">

    <resultMap type="AiModel" id="AiModelResult">
        <result property="modelId" column="model_id"/>
        <result property="modelCode" column="model_code"/>
        <result property="modelName" column="model_name"/>
        <result property="modelType" column="model_type"/>
        <result property="provider" column="provider"/>
        <result property="coverUrl" column="cover_url"/>
        <result property="intro" column="intro"/>
        <result property="status" column="status"/>
        <result property="sort" column="sort"/>
        <result property="remark" column="remark"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <sql id="selectAiModelVo">
        select model_id, model_code, model_name, model_type, provider, cover_url, intro, status, sort, remark,
               create_by, create_time, update_by, update_time
        from ai_c_model
    </sql>

    <select id="selectAiModelById" parameterType="Long" resultMap="AiModelResult">
        <include refid="selectAiModelVo"/>
        where model_id = #{modelId}
    </select>

    <select id="selectAiModelList" parameterType="AiModel" resultMap="AiModelResult">
        <include refid="selectAiModelVo"/>
        <where>
            <if test="modelCode != null and modelCode != ''">
                and model_code like concat('%', #{modelCode}, '%')
            </if>
            <if test="modelName != null and modelName != ''">
                and model_name like concat('%', #{modelName}, '%')
            </if>
            <if test="modelType != null and modelType != ''">
                and model_type = #{modelType}
            </if>
            <if test="provider != null and provider != ''">
                and provider = #{provider}
            </if>
            <if test="status != null and status != ''">
                and status = #{status}
            </if>
        </where>
        order by sort asc, model_id desc
    </select>

    <insert id="insertAiModel" parameterType="AiModel" useGeneratedKeys="true" keyProperty="modelId">
        insert into ai_c_model
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="modelCode != null and modelCode != ''">model_code,</if>
            <if test="modelName != null and modelName != ''">model_name,</if>
            <if test="modelType != null and modelType != ''">model_type,</if>
            <if test="provider != null and provider != ''">provider,</if>
            <if test="coverUrl != null and coverUrl != ''">cover_url,</if>
            <if test="intro != null and intro != ''">intro,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="sort != null">sort,</if>
            <if test="remark != null and remark != ''">remark,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="modelCode != null and modelCode != ''">#{modelCode},</if>
            <if test="modelName != null and modelName != ''">#{modelName},</if>
            <if test="modelType != null and modelType != ''">#{modelType},</if>
            <if test="provider != null and provider != ''">#{provider},</if>
            <if test="coverUrl != null and coverUrl != ''">#{coverUrl},</if>
            <if test="intro != null and intro != ''">#{intro},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="sort != null">#{sort},</if>
            <if test="remark != null and remark != ''">#{remark},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            sysdate()
        </trim>
    </insert>

    <update id="updateAiModel" parameterType="AiModel">
        update ai_c_model
        <set>
            <if test="modelCode != null and modelCode != ''">model_code = #{modelCode},</if>
            <if test="modelName != null and modelName != ''">model_name = #{modelName},</if>
            <if test="modelType != null and modelType != ''">model_type = #{modelType},</if>
            <if test="provider != null">provider = #{provider},</if>
            <if test="coverUrl != null">cover_url = #{coverUrl},</if>
            <if test="intro != null">intro = #{intro},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="sort != null">sort = #{sort},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            update_time = sysdate()
        </set>
        where model_id = #{modelId}
    </update>

    <delete id="deleteAiModelById" parameterType="Long">
        delete from ai_c_model where model_id = #{modelId}
    </delete>

    <delete id="deleteAiModelByIds" parameterType="Long">
        delete from ai_c_model where model_id in
        <foreach item="modelId" collection="array" open="(" separator="," close=")">
            #{modelId}
        </foreach>
    </delete>
</mapper>
