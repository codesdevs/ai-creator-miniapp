<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.AiModelVersionMapper">

    <resultMap type="AiModelVersion" id="AiModelVersionResult">
        <result property="versionId" column="version_id"/>
        <result property="modelId" column="model_id"/>
        <result property="versionCode" column="version_code"/>
        <result property="versionName" column="version_name"/>
        <result property="apiModelName" column="api_model_name"/>
        <result property="powerCost" column="power_cost"/>
        <result property="contextLength" column="context_length"/>
        <result property="inputPrice" column="input_price"/>
        <result property="outputPrice" column="output_price"/>
        <result property="speedLevel" column="speed_level"/>
        <result property="qualityLevel" column="quality_level"/>
        <result property="supportRatio" column="support_ratio"/>
        <result property="supportStyle" column="support_style"/>
        <result property="supportMode" column="support_mode"/>
        <result property="extConfig" column="ext_config"/>
        <result property="status" column="status"/>
        <result property="remark" column="remark"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <result property="modelName" column="model_name"/>
    </resultMap>

    <sql id="selectAiModelVersionVo">
        select v.version_id, v.model_id, v.version_code, v.version_name, v.api_model_name, v.power_cost,
               v.context_length, v.input_price, v.output_price, v.speed_level, v.quality_level, v.support_ratio, v.support_style,
               v.support_mode, v.ext_config, v.status, v.remark, v.create_by, v.create_time, v.update_by, v.update_time,
               m.model_name
        from ai_c_model_version v
        left join ai_c_model m on m.model_id = v.model_id
    </sql>

    <select id="selectAiModelVersionById" parameterType="Long" resultMap="AiModelVersionResult">
        <include refid="selectAiModelVersionVo"/>
        where v.version_id = #{versionId}
    </select>

    <select id="selectAiModelVersionList" parameterType="AiModelVersion" resultMap="AiModelVersionResult">
        <include refid="selectAiModelVersionVo"/>
        <where>
            <if test="modelId != null">and v.model_id = #{modelId}</if>
            <if test="versionCode != null and versionCode != ''">
                and v.version_code like concat('%', #{versionCode}, '%')
            </if>
            <if test="versionName != null and versionName != ''">
                and v.version_name like concat('%', #{versionName}, '%')
            </if>
            <if test="apiModelName != null and apiModelName != ''">
                and v.api_model_name like concat('%', #{apiModelName}, '%')
            </if>
            <if test="status != null and status != ''">and v.status = #{status}</if>
        </where>
        order by v.version_id desc
    </select>

    <select id="selectAiModelVersionListByModelId" parameterType="Long" resultMap="AiModelVersionResult">
        <include refid="selectAiModelVersionVo"/>
        where v.model_id = #{modelId}
        order by v.version_id desc
    </select>

    <insert id="insertAiModelVersion" parameterType="AiModelVersion" useGeneratedKeys="true" keyProperty="versionId">
        insert into ai_c_model_version
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="modelId != null">model_id,</if>
            <if test="versionCode != null and versionCode != ''">version_code,</if>
            <if test="versionName != null and versionName != ''">version_name,</if>
            <if test="apiModelName != null and apiModelName != ''">api_model_name,</if>
            <if test="powerCost != null">power_cost,</if>
            <if test="contextLength != null">context_length,</if>
            <if test="inputPrice != null">input_price,</if>
            <if test="outputPrice != null">output_price,</if>
            <if test="speedLevel != null">speed_level,</if>
            <if test="qualityLevel != null">quality_level,</if>
            <if test="supportRatio != null and supportRatio != ''">support_ratio,</if>
            <if test="supportStyle != null and supportStyle != ''">support_style,</if>
            <if test="supportMode != null and supportMode != ''">support_mode,</if>
            <if test="extConfig != null and extConfig != ''">ext_config,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="remark != null and remark != ''">remark,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="modelId != null">#{modelId},</if>
            <if test="versionCode != null and versionCode != ''">#{versionCode},</if>
            <if test="versionName != null and versionName != ''">#{versionName},</if>
            <if test="apiModelName != null and apiModelName != ''">#{apiModelName},</if>
            <if test="powerCost != null">#{powerCost},</if>
            <if test="contextLength != null">#{contextLength},</if>
            <if test="inputPrice != null">#{inputPrice},</if>
            <if test="outputPrice != null">#{outputPrice},</if>
            <if test="speedLevel != null">#{speedLevel},</if>
            <if test="qualityLevel != null">#{qualityLevel},</if>
            <if test="supportRatio != null and supportRatio != ''">#{supportRatio},</if>
            <if test="supportStyle != null and supportStyle != ''">#{supportStyle},</if>
            <if test="supportMode != null and supportMode != ''">#{supportMode},</if>
            <if test="extConfig != null and extConfig != ''">#{extConfig},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="remark != null and remark != ''">#{remark},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            sysdate()
        </trim>
    </insert>

    <update id="updateAiModelVersion" parameterType="AiModelVersion">
        update ai_c_model_version
        <set>
            <if test="modelId != null">model_id = #{modelId},</if>
            <if test="versionCode != null and versionCode != ''">version_code = #{versionCode},</if>
            <if test="versionName != null and versionName != ''">version_name = #{versionName},</if>
            <if test="apiModelName != null">api_model_name = #{apiModelName},</if>
            <if test="powerCost != null">power_cost = #{powerCost},</if>
            <if test="contextLength != null">context_length = #{contextLength},</if>
            <if test="inputPrice != null">input_price = #{inputPrice},</if>
            <if test="outputPrice != null">output_price = #{outputPrice},</if>
            <if test="speedLevel != null">speed_level = #{speedLevel},</if>
            <if test="qualityLevel != null">quality_level = #{qualityLevel},</if>
            <if test="supportRatio != null">support_ratio = #{supportRatio},</if>
            <if test="supportStyle != null">support_style = #{supportStyle},</if>
            <if test="supportMode != null">support_mode = #{supportMode},</if>
            <if test="extConfig != null">ext_config = #{extConfig},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            update_time = sysdate()
        </set>
        where version_id = #{versionId}
    </update>

    <delete id="deleteAiModelVersionById" parameterType="Long">
        delete from ai_c_model_version where version_id = #{versionId}
    </delete>

    <delete id="deleteAiModelVersionByIds" parameterType="Long">
        delete from ai_c_model_version where version_id in
        <foreach item="versionId" collection="array" open="(" separator="," close=")">
            #{versionId}
        </foreach>
    </delete>
</mapper>
