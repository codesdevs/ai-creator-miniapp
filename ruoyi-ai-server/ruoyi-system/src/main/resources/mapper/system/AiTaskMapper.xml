<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.AiTaskMapper">

    <resultMap type="AiTask" id="AiTaskResult">
        <result property="taskId" column="task_id"/>
        <result property="taskNo" column="task_no"/>
        <result property="userId" column="user_id"/>
        <result property="modelId" column="model_id"/>
        <result property="modelVersionId" column="model_version_id"/>
        <result property="channelId" column="channel_id"/>
        <result property="channelModelRelationId" column="channel_model_relation_id"/>
        <result property="taskType" column="task_type"/>
        <result property="createMode" column="create_mode"/>
        <result property="promptText" column="prompt_text"/>
        <result property="negativePrompt" column="negative_prompt"/>
        <result property="styleCode" column="style_code"/>
        <result property="ratioCode" column="ratio_code"/>
        <result property="sourceUrl" column="source_url"/>
        <result property="status" column="status"/>
        <result property="powerCost" column="power_cost"/>
        <result property="thirdTaskId" column="third_task_id"/>
        <result property="remoteModelName" column="remote_model_name"/>
        <result property="failReason" column="fail_reason"/>
        <result property="requestPayload" column="request_payload"/>
        <result property="responsePayload" column="response_payload"/>
        <result property="submitTime" column="submit_time"/>
        <result property="finishTime" column="finish_time"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <result property="remark" column="remark"/>
        <result property="modelName" column="model_name"/>
        <result property="versionName" column="version_name"/>
        <result property="providerName" column="provider_name"/>
        <result property="channelName" column="channel_name"/>
        <result property="nickName" column="nick_name"/>
    </resultMap>

    <sql id="selectAiTaskVo">
        select t.task_id, t.task_no, t.user_id, t.model_id, t.model_version_id, t.channel_id, t.channel_model_relation_id,
               t.task_type, t.create_mode,
               cast(t.prompt_text as char) as prompt_text, cast(t.negative_prompt as char) as negative_prompt,
               t.style_code, t.ratio_code, t.source_url, t.status, t.power_cost, t.third_task_id, t.remote_model_name,
               t.fail_reason, cast(t.request_payload as char) as request_payload, cast(t.response_payload as char) as response_payload,
               t.submit_time, t.finish_time, t.create_by, t.create_time, t.update_by, t.update_time,
               t.remark, m.model_name, v.version_name, p.provider_name, c.channel_name, u.nick_name
        from ai_c_task t
        left join ai_c_model m on m.model_id = t.model_id
        left join ai_c_model_version v on v.version_id = t.model_version_id
        left join ai_c_provider_channel c on c.channel_id = t.channel_id
        left join ai_c_provider p on p.provider_id = c.provider_id
        left join ai_c_user u on u.user_id = t.user_id
    </sql>

    <select id="selectAiTaskById" parameterType="Long" resultMap="AiTaskResult">
        <include refid="selectAiTaskVo"/>
        where t.task_id = #{taskId}
    </select>

    <select id="selectAiTaskList" parameterType="AiTask" resultMap="AiTaskResult">
        <include refid="selectAiTaskVo"/>
        <where>
            <if test="taskNo != null and taskNo != ''">and t.task_no like concat('%', #{taskNo}, '%')</if>
            <if test="userId != null">and t.user_id = #{userId}</if>
            <if test="modelId != null">and t.model_id = #{modelId}</if>
            <if test="modelVersionId != null">and t.model_version_id = #{modelVersionId}</if>
            <if test="providerName != null and providerName != ''">and p.provider_name like concat('%', #{providerName}, '%')</if>
            <if test="channelName != null and channelName != ''">and c.channel_name like concat('%', #{channelName}, '%')</if>
            <if test="remoteModelName != null and remoteModelName != ''">and t.remote_model_name like concat('%', #{remoteModelName}, '%')</if>
            <if test="taskType != null and taskType != ''">and t.task_type = #{taskType}</if>
            <if test="createMode != null and createMode != ''">and t.create_mode = #{createMode}</if>
            <if test="status != null and status != ''">and t.status = #{status}</if>
            <if test="processingOnly == '1'">and t.status in ('PENDING', 'WAITING', 'RUNNING')</if>
            <if test="requestRecorded != null and requestRecorded != ''">
                <choose>
                    <when test="requestRecorded == '1'">and t.request_payload is not null and t.request_payload != ''</when>
                    <when test="requestRecorded == '0'">and (t.request_payload is null or t.request_payload = '')</when>
                </choose>
            </if>
            <if test="responseRecorded != null and responseRecorded != ''">
                <choose>
                    <when test="responseRecorded == '1'">and t.response_payload is not null and t.response_payload != ''</when>
                    <when test="responseRecorded == '0'">and (t.response_payload is null or t.response_payload = '')</when>
                </choose>
            </if>
        </where>
        order by t.task_id desc
    </select>

    <insert id="insertAiTask" parameterType="AiTask" useGeneratedKeys="true" keyProperty="taskId">
        insert into ai_c_task
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="taskNo != null and taskNo != ''">task_no,</if>
            <if test="userId != null">user_id,</if>
            <if test="modelId != null">model_id,</if>
            <if test="modelVersionId != null">model_version_id,</if>
            <if test="channelId != null">channel_id,</if>
            <if test="channelModelRelationId != null">channel_model_relation_id,</if>
            <if test="taskType != null and taskType != ''">task_type,</if>
            <if test="createMode != null and createMode != ''">create_mode,</if>
            <if test="promptText != null and promptText != ''">prompt_text,</if>
            <if test="negativePrompt != null and negativePrompt != ''">negative_prompt,</if>
            <if test="styleCode != null and styleCode != ''">style_code,</if>
            <if test="ratioCode != null and ratioCode != ''">ratio_code,</if>
            <if test="sourceUrl != null and sourceUrl != ''">source_url,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="powerCost != null">power_cost,</if>
            <if test="thirdTaskId != null and thirdTaskId != ''">third_task_id,</if>
            <if test="remoteModelName != null and remoteModelName != ''">remote_model_name,</if>
            <if test="failReason != null and failReason != ''">fail_reason,</if>
            <if test="requestPayload != null and requestPayload != ''">request_payload,</if>
            <if test="responsePayload != null and responsePayload != ''">response_payload,</if>
            <if test="submitTime != null">submit_time,</if>
            <if test="finishTime != null">finish_time,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            <if test="remark != null and remark != ''">remark,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="taskNo != null and taskNo != ''">#{taskNo},</if>
            <if test="userId != null">#{userId},</if>
            <if test="modelId != null">#{modelId},</if>
            <if test="modelVersionId != null">#{modelVersionId},</if>
            <if test="channelId != null">#{channelId},</if>
            <if test="channelModelRelationId != null">#{channelModelRelationId},</if>
            <if test="taskType != null and taskType != ''">#{taskType},</if>
            <if test="createMode != null and createMode != ''">#{createMode},</if>
            <if test="promptText != null and promptText != ''">#{promptText},</if>
            <if test="negativePrompt != null and negativePrompt != ''">#{negativePrompt},</if>
            <if test="styleCode != null and styleCode != ''">#{styleCode},</if>
            <if test="ratioCode != null and ratioCode != ''">#{ratioCode},</if>
            <if test="sourceUrl != null and sourceUrl != ''">#{sourceUrl},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="powerCost != null">#{powerCost},</if>
            <if test="thirdTaskId != null and thirdTaskId != ''">#{thirdTaskId},</if>
            <if test="remoteModelName != null and remoteModelName != ''">#{remoteModelName},</if>
            <if test="failReason != null and failReason != ''">#{failReason},</if>
            <if test="requestPayload != null and requestPayload != ''">#{requestPayload},</if>
            <if test="responsePayload != null and responsePayload != ''">#{responsePayload},</if>
            <if test="submitTime != null">#{submitTime},</if>
            <if test="finishTime != null">#{finishTime},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            <if test="remark != null and remark != ''">#{remark},</if>
            sysdate()
        </trim>
    </insert>

    <update id="updateAiTask" parameterType="AiTask">
        update ai_c_task
        <set>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="thirdTaskId != null">third_task_id = #{thirdTaskId},</if>
            <if test="failReason != null">fail_reason = #{failReason},</if>
            <if test="requestPayload != null">request_payload = #{requestPayload},</if>
            <if test="responsePayload != null">response_payload = #{responsePayload},</if>
            <if test="finishTime != null">finish_time = #{finishTime},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            update_time = sysdate()
        </set>
        where task_id = #{taskId}
    </update>
</mapper>
