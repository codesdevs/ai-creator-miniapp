<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.AiTaskResultMapper">

    <resultMap type="AiTaskResult" id="AiTaskResultMap">
        <result property="resultId" column="result_id"/>
        <result property="taskId" column="task_id"/>
        <result property="resultType" column="result_type"/>
        <result property="fileUrl" column="file_url"/>
        <result property="coverUrl" column="cover_url"/>
        <result property="width" column="width"/>
        <result property="height" column="height"/>
        <result property="duration" column="duration"/>
        <result property="seqNo" column="seq_no"/>
        <result property="createTime" column="create_time"/>
    </resultMap>

    <select id="selectAiTaskResultListByTaskId" parameterType="Long" resultMap="AiTaskResultMap">
        select result_id, task_id, result_type, file_url, cover_url, width, height, duration, seq_no, create_time
        from ai_c_task_result
        where task_id = #{taskId}
        order by seq_no asc, result_id asc
    </select>

    <insert id="insertAiTaskResult" parameterType="AiTaskResult" useGeneratedKeys="true" keyProperty="resultId">
        insert into ai_c_task_result
        (task_id, result_type, file_url, cover_url, width, height, duration, seq_no, create_time)
        values
        (#{taskId}, #{resultType}, #{fileUrl}, #{coverUrl}, #{width}, #{height}, #{duration}, #{seqNo}, sysdate())
    </insert>
</mapper>
